# InsightX Environment Configuration
# Copy this file to .env and fill in your values

# Google Gemini API Key（必填）
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Serper API Key（必填：店家評論模式使用）
# 以下是公開的體驗用 Key，歡迎直接使用測試
# 申請自己的 Key：https://serper.dev/
SERPER_API_KEY=d270c73722477e6a5883c1dd9938530d9ff94daa

# YouTube Data API v3 Key（v2.0.0：YouTube 頻道模式主要路徑）
# 申請步驟：Google Cloud Console → 啟用 YouTube Data API v3 → 建立 API Key
# 免費額度：10,000 units/day（單支影片留言爬取約消耗 3-10 units）
# https://console.cloud.google.com/apis/library/youtube.googleapis.com
#
# 若留空，系統會自動 fallback 到 youtube-comment-downloader（無 key、無配額）
YOUTUBE_API_KEY=your_youtube_api_key_here

# YouTube 抓取模式 (v2.0.0 新增)
#   auto          - 預設：官方 API 主 / 失敗時由備用 library (youtube-comment-downloader) 接手
#   force-ytdlp   - 強制走備用 library（值保留舊名以向下相容；測試備用路徑時用）
#   off           - 只用官方 API，失敗直接報錯
YOUTUBE_FALLBACK_MODE=auto

# Environment Mode
ENVIRONMENT=development
