    /* YouTube — Stripe 風不再特別標識，併入主 accent */
    --yt: #635BFF;

    /* Type — 保留 Manrope + Noto Sans TC + JetBrains Mono（下次風格調整再動） */
    --sans: "Manrope", "Noto Sans TC", -apple-system, BlinkMacSystemFont, "SF Pro Display", sans-serif;
    --mono: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
  }

  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
    font-family: var(--sans);
    background: var(--paper);
    color: var(--ink);
    -webkit-font-smoothing: antialiased;
    line-height: 1.45;
    font-feature-settings: "ss01", "ss02", "cv11", "tnum";
  }
  button { font-family: inherit; cursor: pointer; }
  input, textarea { font-family: inherit; }
  ::selection { background: var(--ink); color: var(--paper); }

  .mono { font-family: var(--mono); font-feature-settings: "tnum"; }
  .tabular { font-variant-numeric: tabular-nums; }

  /* Scrollbar */
  ::-webkit-scrollbar { width: 10px; height: 10px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: oklch(0.85 0 0); border-radius: 10px; }
  ::-webkit-scrollbar-thumb:hover { background: oklch(0.7 0 0); }

  /* Focus */
  :focus-visible { outline: 2px solid var(--blue); outline-offset: 2px; border-radius: 4px; }

  /* Prevent flash */
  #root:empty::before {
    content: "";
    position: fixed; inset: 0;
    background: var(--paper);
    z-index: 9999;
  }

  /* Utilities */
  .kicker {
    font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase;
    font-weight: 600; color: var(--g3);
  }
  .tag {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 4px 10px; font-size: 11px; font-weight: 500;
    border-radius: 999px; letter-spacing: 0.02em;
  }

  /* Animations */
  @keyframes fadeUp { from { opacity: 0; transform: translateY(14px); } to { opacity: 1; transform: none; } }
  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
  @keyframes growBar { from { transform: scaleX(0); } to { transform: scaleX(1); } }
  @keyframes dotPulse { 0%,100% { opacity: 0.3; transform: scale(0.8); } 50% { opacity: 1; transform: scale(1.05); } }
  @keyframes shine { 0% { transform: translateX(-100%); } 100% { transform: translateX(100%); } }
  @keyframes floaty { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-4px); } }

  .fade-up { animation: fadeUp 0.7s cubic-bezier(.2,.7,.2,1) both; }
  .fade-in { animation: fadeIn 0.4s ease both; }

  /* Reveal-on-scroll */
  .reveal { opacity: 0; transform: translateY(20px); transition: opacity .8s cubic-bezier(.2,.7,.2,1), transform .8s cubic-bezier(.2,.7,.2,1); }
  .reveal.in { opacity: 1; transform: none; }

  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { scrollbar-width: none; }

  /* Screen transitions */
  .screen { animation: fadeIn .4s ease both; }

  /* Dark section — inverts palette locally */
  .dark {
    background: var(--ink); color: var(--paper);
  }
  .dark .kicker { color: oklch(0.72 0 0); }

  /* Responsive */
  .show-sm { display: none !important; }
  @media (max-width: 900px) {
    .pick-grid { grid-template-columns: 1fr !important; gap: 16px !important; }
    .two-col { grid-template-columns: 1fr !important; gap: 32px !important; }
    .three-col { grid-template-columns: 1fr !important; }
