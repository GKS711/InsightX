// ===== Tweaks panel (v2) =====
const TweaksPanel = ({ tweaks, setTweak, onJump }) => {
  const [open, setOpen] = React.useState(true);
  const [active, setActive] = React.useState(false);

  React.useEffect(() => {
    const handler = (e) => {
      const d = e.data;
      if (!d || typeof d !== "object") return;
      if (d.type === "__activate_edit_mode") setActive(true);
      if (d.type === "__deactivate_edit_mode") setActive(false);
    };
    window.addEventListener("message", handler);
    try { window.parent.postMessage({ type: "__edit_mode_available" }, "*"); } catch {}
    return () => window.removeEventListener("message", handler);
  }, []);

  const persist = (patch) => {
    setTweak(patch);
    try {
      window.parent.postMessage({ type: "__edit_mode_set_keys", edits: patch }, "*");
    } catch {}
  };

  if (!active) return null;

  return (
    <div style={{
      position: "fixed", bottom: 16, right: 16, zIndex: 200,
      width: 320, background: "var(--paper)", border: "1px solid var(--g1)",
      borderRadius: 16, boxShadow: "0 20px 60px -20px rgba(0,0,0,0.35)",
      overflow: "hidden", fontFamily: "var(--sans)"
    }}>
      <div style={{
        display: "flex", alignItems: "center", justifyContent: "space-between",
        padding: "12px 16px", borderBottom: open ? "1px solid var(--g1)" : "none",
        background: "var(--ink)", color: "var(--paper)"
      }}>
        <div style={{ display: "flex", alignItems: "center", gap: 8 }}>
          <Sparkle size={14}/>
          <span style={{ fontSize: 13, fontWeight: 600, letterSpacing: "-0.005em" }}>Tweaks</span>
        </div>
        <button onClick={() => setOpen(o => !o)} style={{
          background: "transparent", border: "none", color: "var(--paper)", cursor: "pointer", padding: 4
        }}>
          {open ? <ChevronDown size={14}/> : <ChevronLeft size={14}/>}
        </button>
      </div>
      {open && (
        <div style={{ padding: 16, display: "grid", gap: 14 }}>
          <div>
            <div className="kicker" style={{ marginBottom: 8 }}>跳至畫面</div>
            <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 6 }}>
              {[
                ["landing", "首頁"],
                ["shop", "店家 Dashboard"],
                ["yt-creator", "YT・創作者"],
                ["yt-shop", "YT・店家"],
                ["yt-brand", "YT・品牌"]
              ].map(([k, l]) => (
                <button key={k} onClick={() => onJump(k)} style={{
                  padding: "8px 10px", fontSize: 11, border: "1px solid var(--g1)",
                  borderRadius: 10, background: "var(--paper)", cursor: "pointer",
                  textAlign: "left", fontFamily: "var(--sans)", fontWeight: 500
                }}>{l}</button>
              ))}
            </div>
          </div>
          <div>
            <div className="kicker" style={{ marginBottom: 8 }}>主色</div>
            <div style={{ display: "flex", gap: 8 }}>
              {[
                ["coral", "var(--coral)"],
                ["ink", "var(--ink)"],
                ["blue", "var(--blue)"]
              ].map(([k, c]) => (
                <button key={k} onClick={() => persist({ accent: k })} style={{
                  width: 28, height: 28, borderRadius: "50%", background: c,
                  border: tweaks.accent === k ? "2px solid var(--ink)" : "2px solid var(--g1)",
                  cursor: "pointer", padding: 0
                }}/>
              ))}
            </div>
          </div>
        </div>
      )}
    </div>
  );
};

