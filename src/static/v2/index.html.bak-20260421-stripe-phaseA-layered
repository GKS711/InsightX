  :root {
    /* Stripe-inspired palette (2026-04-21 color redesign)
       - 單一 accent = Stripe purple #635BFF
       - ink = Stripe deep navy (不用純黑，降低壓迫)
       - 灰階全系 Stripe-blue-tinted neutral scale
       - 背景固定純白，不鋪暖底色 */
    --ink: #0A2540;                         /* Stripe deep navy */
    --paper: #FFFFFF;
    --warm: #F6F9FC;                        /* 原本的 warm off-white → Stripe panel 藍灰 */
    --smoke: #F6F9FC;                       /* 與 --warm 同色，統一 off-white tint */
    --g1: #E6EBF1;                          /* 最淺 Stripe 灰（分隔線 / hover 底） */
    --g2: #AAB7C4;                          /* 中淺（placeholder / icon 弱色） */
    --g3: #8898AA;                          /* 中深（次要文字 / metadata） */
    --g4: #425466;                          /* 深灰（主要文字 contrast 用） */

    /* Accents — 收斂成「單一 Stripe 紫」single-accent system */
    --coral: #635BFF;                       /* 原 coral（暖橙）→ Stripe 紫 */
    --coral-soft: #EFEFFD;                  /* 紫淺底 */
    --blue: #635BFF;                        /* 原 apple-blue → 合流到主紫 */
    --blue-soft: #EFEFFD;

    /* Semantic — 低頻使用，只在明確語意場景出現 */
    --pos: #00C853;                         /* Stripe-like 米綠（正面數值 / success toast） */
    --neg: #FF5A5F;                         /* 涼紅（錯誤 / 負面 / 警示） */
