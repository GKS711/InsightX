};

// ---- Kicker — small uppercase label ----
const Kicker = ({ children, tone = "ink", style = {} }) => (
  <div className="kicker" style={{
    color: tone === "light" ? "oklch(0.72 0 0)" : tone === "coral" ? "var(--coral)" :
           tone === "blue" ? "var(--blue)" : "var(--g3)",
    ...style
  }}>{children}</div>
);

// ---- Pill — compact label ----
const Pill = ({ children, tone = "ink", size = "md", style = {} }) => {
  const palettes = {
    ink: { bg: "var(--ink)", fg: "var(--paper)" },
    paper: { bg: "var(--paper)", fg: "var(--ink)" },
    smoke: { bg: "var(--smoke)", fg: "var(--ink)" },
    coral: { bg: "var(--coral)", fg: "var(--paper)" },
    coralSoft: { bg: "var(--coral-soft)", fg: "var(--coral)" },
    blue: { bg: "var(--blue)", fg: "var(--paper)" },
    blueSoft: { bg: "var(--blue-soft)", fg: "var(--blue)" },
    pos: { bg: "var(--coral-soft)", fg: "var(--coral)" },
    neg: { bg: "oklch(0.94 0.01 258)", fg: "var(--g4)" },
    outline: { bg: "transparent", fg: "var(--ink)", border: "var(--ink)" }
  };
  const p = palettes[tone] || palettes.ink;
  return (
    <span style={{
      display: "inline-flex", alignItems: "center", gap: 5,
      padding: size === "sm" ? "2px 8px" : "4px 11px",
      fontSize: size === "sm" ? 10 : 11, fontWeight: 600,
      background: p.bg, color: p.fg,
      border: p.border ? `1px solid ${p.border}` : "none",
      borderRadius: 999, letterSpacing: "0.01em", lineHeight: 1.4,
      ...style
    }}>{children}</span>
  );
};

// ---- Btn — Apple-like, rounded-full ----
const Btn = ({ children, tone = "ink", size = "md", onClick, disabled, block, href, ...p }) => {
  const h = size === "lg" ? 52 : size === "sm" ? 34 : 44;
  const fs = size === "lg" ? 15 : size === "sm" ? 12 : 14;
  const px = size === "lg" ? 26 : size === "sm" ? 16 : 20;
  const palettes = {
    ink: { bg: "var(--ink)", fg: "var(--paper)", border: "var(--ink)" },
    paper: { bg: "var(--paper)", fg: "var(--ink)", border: "var(--paper)" },
    coral: { bg: "var(--coral)", fg: "var(--paper)", border: "var(--coral)" },
    blue: { bg: "var(--blue)", fg: "var(--paper)", border: "var(--blue)" },
    ghost: { bg: "transparent", fg: "var(--ink)", border: "var(--g1)" },
    ghostLight: { bg: "transparent", fg: "var(--paper)", border: "oklch(0.45 0 0)" }
  };
  const styles = palettes[tone] || palettes.ink;
  const Tag = href ? "a" : "button";
  return (
    <Tag onClick={onClick} disabled={disabled} href={href}
      style={{
        height: h, padding: `0 ${px}px`,
        background: styles.bg, color: styles.fg,
        border: `1px solid ${styles.border}`,
        borderRadius: 999, textDecoration: "none",
        fontFamily: "var(--sans)", fontSize: fs, fontWeight: 600,
        display: "inline-flex", alignItems: "center", justifyContent: "center", gap: 8,
        width: block ? "100%" : "auto", cursor: disabled ? "not-allowed" : "pointer",
        opacity: disabled ? 0.35 : 1,
        transition: "transform .12s, background .2s, color .2s, border-color .2s",
        letterSpacing: "-0.005em", whiteSpace: "nowrap"
      }}
      onMouseDown={(e) => !disabled && (e.currentTarget.style.transform = "scale(0.97)")}
      onMouseUp={(e) => (e.currentTarget.style.transform = "none")}
      onMouseLeave={(e) => (e.currentTarget.style.transform = "none")}
      {...p}
    >{children}</Tag>
  );
};

// ---- StarRow ----
const StarRow = ({ rating, size = 14, color }) => {
  const full = Math.floor(rating);
  const hasHalf = rating - full >= 0.5;
  return (
    <div style={{ display: "inline-flex", gap: 2, color: color || "var(--coral)" }}>
      {[0,1,2,3,4].map(i => (
        <StarFill key={i} size={size} style={{ opacity: i < full ? 1 : (i === full && hasHalf ? 0.5 : 0.15) }}/>
      ))}
    </div>
  );
};

