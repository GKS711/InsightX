        }}/>
      </div>
    </div>
  );
};

// ---- Sparkline ----
const Sparkline = ({ data, w = 240, h = 50, tone = "ink" }) => {
  const min = Math.min(...data), max = Math.max(...data);
  const range = max - min || 1;
  const step = w / (data.length - 1);
  const pts = data.map((v, i) => [i * step, h - ((v - min) / range) * h * 0.85 - h * 0.08]);
  const d = pts.map((p, i) => `${i === 0 ? "M" : "L"}${p[0].toFixed(1)},${p[1].toFixed(1)}`).join(" ");
  const fillD = `${d} L${w},${h} L0,${h} Z`;
  const color = tone === "coral" ? "var(--coral)" : tone === "blue" ? "var(--blue)" : "var(--ink)";
  return (
    <svg width={w} height={h} style={{ display: "block", overflow: "visible" }}>
      <defs>
        <linearGradient id={`spg-${tone}`} x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stopColor={color} stopOpacity="0.18"/>
          <stop offset="100%" stopColor={color} stopOpacity="0"/>
        </linearGradient>
      </defs>
      <path d={fillD} fill={`url(#spg-${tone})`}/>
      <path d={d} stroke={color} strokeWidth="2" fill="none" strokeLinecap="round" strokeLinejoin="round"/>
      <circle cx={pts[pts.length-1][0]} cy={pts[pts.length-1][1]} r="3.5" fill={color}/>
      <circle cx={pts[pts.length-1][0]} cy={pts[pts.length-1][1]} r="7" fill={color} opacity="0.15"/>
    </svg>
  );
};

// ---- Donut ----
const Donut = ({ pos, neu, neg, size = 140, stroke = 12 }) => {
  const r = size / 2 - stroke/2 - 2, c = 2 * Math.PI * r;
  const total = pos + neu + neg;
  const posLen = (pos / total) * c;
  const neuLen = (neu / total) * c;
  const negLen = (neg / total) * c;
  return (
    <svg width={size} height={size} style={{ transform: "rotate(-90deg)" }}>
      <circle cx={size/2} cy={size/2} r={r} stroke="var(--g1)" strokeWidth={stroke} fill="none"/>
      <circle cx={size/2} cy={size/2} r={r} stroke="var(--coral)" strokeWidth={stroke} fill="none"
              strokeDasharray={`${posLen} ${c}`} strokeDashoffset="0" strokeLinecap="round"/>
      <circle cx={size/2} cy={size/2} r={r} stroke="var(--g2)" strokeWidth={stroke} fill="none"
              strokeDasharray={`${neuLen} ${c}`} strokeDashoffset={-posLen} strokeLinecap="round"/>
      <circle cx={size/2} cy={size/2} r={r} stroke="var(--g4)" strokeWidth={stroke} fill="none"
              strokeDasharray={`${negLen} ${c}`} strokeDashoffset={-(posLen + neuLen)} strokeLinecap="round"/>
    </svg>
  );
};

// ---- Reveal wrapper — fades in when scrolled into view ----
const Reveal = ({ children, delay = 0, as: Tag = "div", style = {}, ...p }) => {
  const ref = React.useRef(null);
  const [visible, setVisible] = React.useState(false);
  React.useEffect(() => {
    if (!ref.current) return;
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          setVisible(true);
          io.disconnect();
        }
      });
    }, { threshold: 0.12, rootMargin: "-5% 0px" });
    io.observe(ref.current);
    return () => io.disconnect();
  }, []);
  return (
    <Tag ref={ref} className={`reveal ${visible ? "in" : ""}`}
         style={{ transitionDelay: `${delay}s`, ...style }} {...p}>
      {children}
    </Tag>
  );
};

