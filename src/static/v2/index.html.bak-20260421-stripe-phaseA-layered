// ---- Engagement timeline — key moments through the video ----
const YTEngagementTimeline = () => {
  const W = 1000, H = 180;
  const data = YT_VIDEO.engagement;
  const step = W / (data.length - 1);
  const pts = data.map((v, i) => [i * step, H - v * H * 0.85 - H * 0.08]);
  const linePath = pts.map((p, i) => `${i === 0 ? "M" : "L"}${p[0].toFixed(1)},${p[1].toFixed(1)}`).join(" ");
  const areaPath = `${linePath} L${W},${H} L0,${H} Z`;

  // Convert highlight timestamps to x positions — video is 8:42 = 522s, data = 33 points (roughly every 16s)
  const totalSec = 8 * 60 + 42;
  const tToX = (mmss) => {
    const [m, s] = mmss.split(":").map(Number);
    return ((m * 60 + s) / totalSec) * W;
  };

  return (
    <section style={{ padding: "140px 24px 100px" }}>
      <div style={{ maxWidth: 1280, margin: "0 auto" }}>
        <Reveal>
          <SectionHead
            kicker="§01 · 觀眾反應高峰"
            title={<>8 分 42 秒裡，<br/><span style={{ color: "var(--yt)" }}>有 4 個時刻點燃留言區。</span></>}
            sub="我們把每一則留言對齊影片時間戳，找出觀眾反應最熱烈的那幾秒——這是你下一支影片、或回覆策略的起點。"
          />
        </Reveal>

        <Reveal delay={0.15}>
          <Card pad={40} style={{ marginTop: 64 }}>
            <svg viewBox={`0 0 ${W} ${H + 60}`} preserveAspectRatio="none" style={{ width: "100%", height: "auto", display: "block", overflow: "visible" }}>
              <defs>
                <linearGradient id="ytArea" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0%" stopColor="var(--yt)" stopOpacity="0.22"/>
                  <stop offset="100%" stopColor="var(--yt)" stopOpacity="0"/>
                </linearGradient>
              </defs>
              {/* Baseline */}
              <line x1="0" y1={H} x2={W} y2={H} stroke="var(--g1)" strokeWidth="1"/>
              {/* Area */}
              <path d={areaPath} fill="url(#ytArea)"/>
              {/* Line */}
              <path d={linePath} stroke="var(--yt)" strokeWidth="2.5" fill="none" strokeLinecap="round" strokeLinejoin="round"/>

              {/* Highlight markers */}
              {YT_HIGHLIGHTS.map((h, i) => {
                const x = tToX(h.t);
                const color = h.type === "pos" ? "var(--coral)" : "var(--g4)";
                return (
                  <g key={i}>
                    <line x1={x} y1="0" x2={x} y2={H} stroke={color} strokeWidth="1" strokeDasharray="3 3" opacity="0.5"/>
                    <circle cx={x} cy={pts.find(p => Math.abs(p[0] - x) < step)[1]} r="7" fill={color}/>
                    <circle cx={x} cy={pts.find(p => Math.abs(p[0] - x) < step)[1]} r="14" fill={color} opacity="0.2"/>
                    <text x={x} y={H + 40} textAnchor="middle" fontSize="12" fontFamily="var(--mono)" fill="var(--g4)" fontWeight="600">
                      {h.t}
                    </text>
                    <text x={x} y={H + 56} textAnchor="middle" fontSize="11" fill="var(--g3)">
                      {h.mentions} 則
                    </text>
                  </g>
                );
              })}
            </svg>

            {/* Legend / axis labels */}
            <div style={{
              display: "flex", justifyContent: "space-between", fontSize: 11,
              color: "var(--g3)", fontFamily: "var(--mono)", letterSpacing: "0.06em", marginTop: 8
            }}>
              <span>00:00</span><span>02:10</span><span>04:21</span><span>06:31</span><span>{YT_VIDEO.duration}</span>
            </div>
          </Card>
        </Reveal>

        {/* Highlight cards */}
        <div className="four-col" style={{
          marginTop: 32, display: "grid", gridTemplateColumns: "repeat(4, 1fr)", gap: 16
        }}>
          {YT_HIGHLIGHTS.map((h, i) => (
            <Reveal key={i} delay={i * 0.08}>
              <HighlightCard h={h}/>
            </Reveal>
          ))}
        </div>
      </div>
    </section>
  );
};

