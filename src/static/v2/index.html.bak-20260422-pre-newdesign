];

const AiToolsPanel = ({ sectionKicker, title, sub }) => {
  const ix = useIX();
  const platform = ix.state.mode.currentPlatform;
  const ytRole = platform === "youtube" ? ix.state.mode.ytRoleSelection : null;
  const analyzeData = ix.state.features.analyze.data;
  const inner = React.useMemo(() => unwrapAnalyze(analyzeData), [analyzeData]);
  const goodText = React.useMemo(() => joinThemesAsText(inner?.good), [inner]);
  const badText = React.useMemo(() => joinThemesAsText(inner?.bad), [inner]);
  const hasRealData = !!inner;

  const [active, setActive] = React.useState("trainingScript");
  const [copied, setCopied] = React.useState(false);

  const activeTab = AI_TOOL_TABS.find((t) => t.key === active) || AI_TOOL_TABS[0];
  const slice = ix.state.features[activeTab.key];

  const trigger = React.useCallback((tabKey) => {
    const tab = AI_TOOL_TABS.find((t) => t.key === tabKey);
    if (!tab) return;
    const body = tab.bodyFrom(goodText, badText);
    const fn = ix.lib.Adapters[tab.adapter];
    if (typeof fn !== "function") return;
    fn({ ...body, platform, ytRole, dispatch: ix.dispatch });
  }, [goodText, badText, platform, ytRole, ix.dispatch, ix.lib]);

  // tab 首次切過來且尚未 fetch 時 → auto trigger
  React.useEffect(() => {
    if (!hasRealData) return;
    if (slice.status !== "idle") return;
    trigger(active);
  }, [active, slice.status, hasRealData]);

  const text = slice.status === "ready" ? slice.data?.[activeTab.resultKey] : null;
  const isLoading = slice.status === "loading";
  const isFailed = slice.status === "failed";

  const copy = () => {
    if (!text) return;
    try {
      navigator.clipboard.writeText(text);
      setCopied(true);
      setTimeout(() => setCopied(false), 1500);
    } catch {}
  };

  const retry = () => trigger(active);

  return (
    <section style={{ padding: "140px 24px", background: "var(--warm)" }}>
      <div style={{ maxWidth: 1280, margin: "0 auto" }}>
        <Reveal>
          <SectionHead
            kicker={
              !hasRealData ? sectionKicker + "（等待分析完成）"
              : isLoading ? sectionKicker + "（AI 生成中…）"
              : isFailed ? sectionKicker + "（載入失敗 · 可重試）"
              : sectionKicker
            }
            title={title}
            sub={sub}
          />
        </Reveal>

        <div style={{ marginTop: 64, display: "grid", gridTemplateColumns: "240px 1fr", gap: 28 }} className="two-col">
          {/* Tab rail */}
          <div>
            {AI_TOOL_TABS.map((t) => {
