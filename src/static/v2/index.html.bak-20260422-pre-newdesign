// 真實後端每次只回一個 topic 的 reply，因此 UI 端需要 per-topic cache 才能流暢切 tab。
const ShopRepliesSection = () => {
  const ix = useIX();
  const vm = useShopViewModel();
  const replySlice = ix.state.features.reply;

  // 動態 tab 列表：
  //   真實分析有 vm.themesNeg 時 → 取 label；否則 fallback 到 REPLIES mock keys
  //   mock 版本保留原標題「出餐速度慢 / 環境清潔」等，確保 demo 資料完整
  const mockTopics = Object.keys(REPLIES);
  const realTopics = Array.isArray(vm.themesNeg) && vm.hasRealData
    ? vm.themesNeg.slice(0, 4).map((t) => t.label).filter(Boolean)
    : [];
  const topics = realTopics.length ? realTopics : mockTopics;

  const [active, setActive] = React.useState(topics[0] || mockTopics[0]);
  const [cache, setCache] = React.useState({});          // {topic: replyMarkdown}
  const [failedTopic, setFailedTopic] = React.useState(null);
  const inflightTopic = React.useRef(null);
  const [copied, setCopied] = React.useState(false);

  // 當 topics 列表切換（real vs mock）時，若 active 不在新列表中就重設
  React.useEffect(() => {
    if (!topics.includes(active)) {
      setActive(topics[0] || mockTopics[0]);
    }
  }, [topics.join("|")]);

  // 監聽 reply slice 狀態轉移，把結果寫入 cache
  React.useEffect(() => {
    if (!inflightTopic.current) return;
    if (replySlice.status === "ready" && replySlice.data?.reply) {
      const t = inflightTopic.current;
      setCache((prev) => ({ ...prev, [t]: String(replySlice.data.reply) }));
      setFailedTopic(null);
      inflightTopic.current = null;
    } else if (replySlice.status === "failed") {
      setFailedTopic(inflightTopic.current);
      inflightTopic.current = null;
    }
  }, [replySlice.status, replySlice.requestId]);

  const platform = ix.state.mode.currentPlatform;
  const ytRole = platform === "youtube" ? ix.state.mode.ytRoleSelection : null;

  const triggerFetch = (topic) => {
    if (!topic) return;
    if (cache[topic]) return;                      // cache hit 不重打
    if (inflightTopic.current === topic) return;   // 同一 topic 進行中
    inflightTopic.current = topic;
    setFailedTopic(null);
    ix.lib.Adapters.fetchReply({
      topic,
      platform,
      ytRole,
      dispatch: ix.dispatch,
    });
  };

  const onSelect = (topic) => {
    setActive(topic);
    triggerFetch(topic);
  };

  const retry = () => {
    // 清掉 cache 重打
    setCache((prev) => { const { [active]: _, ...rest } = prev; return rest; });
    setFailedTopic(null);
    triggerFetch(active);
  };

  const replyText = cache[active];
  const isLoadingActive = replySlice.status === "loading" && inflightTopic.current === active;
  const isFailedActive = failedTopic === active;

  // fallback：mock REPLIES 有的話先用 mock body + tone
  const mockEntry = REPLIES[active];
  const toneLabel = replyText ? "由 AI 根據你的評論生成" : mockEntry?.tone || "範例回覆";

  const copyText = replyText || mockEntry?.body || "";
  const copy = () => {
    if (!copyText) return;
    try {
      navigator.clipboard.writeText(copyText);
      setCopied(true);
      setTimeout(() => setCopied(false), 1500);
    } catch {}
  };

  return (
    <section style={{ padding: "140px 24px" }}>
      <div style={{ maxWidth: 1280, margin: "0 auto" }}>
        <Reveal>
          <SectionHead
            kicker={
              isLoadingActive ? "§06 · 回覆草稿（AI 生成中…）"
              : isFailedActive ? "§06 · 回覆草稿（載入失敗 · 顯示示範）"
              : "§06 · 回覆草稿"
            }
            title={<>負評不可怕。<br/>不回才是。</>}
            sub={vm.hasRealData
              ? "我們把你本次分析裡最嚴重的幾個抱怨列在左側，點一下由 AI 針對該情境替你寫草稿。"
              : "針對最常見的兩類負評，我們寫好真誠、具體、不推卸責任的回覆模板。點擊複製，調整細節後即可送出。"}
          />
        </Reveal>
        <div className="two-col" style={{ marginTop: 64, display: "grid", gridTemplateColumns: "260px 1fr", gap: 32 }}>
          <div>
            {topics.map((k) => {
              const hasCache = !!cache[k];
              const isActive = active === k;
              return (
                <button key={k} onClick={() => onSelect(k)} disabled={replySlice.status === "loading" && !isActive} style={{
                  display: "block", width: "100%", textAlign: "left",
                  padding: "14px 16px", marginBottom: 8,
                  background: isActive ? "var(--ink)" : "var(--paper)",
                  color: isActive ? "var(--paper)" : "var(--ink)",
                  border: "1px solid " + (isActive ? "var(--ink)" : "var(--g1)"),
                  borderRadius: 12,
                  cursor: replySlice.status === "loading" && !isActive ? "not-allowed" : "pointer",
                  opacity: replySlice.status === "loading" && !isActive ? 0.5 : 1,
                  fontFamily: "var(--sans)", fontSize: 14, fontWeight: 500, letterSpacing: "-0.005em",
                  display: "flex", justifyContent: "space-between", alignItems: "center", gap: 8
                }}>
                  <span>{k}</span>
                  {hasCache && <Dot size={5} color={isActive ? "var(--coral)" : "var(--coral)"}/>}
                </button>
              );
            })}
            {vm.hasRealData && (
              <div style={{ fontSize: 11, color: "var(--g3)", marginTop: 12, lineHeight: 1.5, letterSpacing: "-0.005em" }}>
                <Dot size={5} color="var(--coral)" style={{ marginRight: 6 }}/>
                小圓點代表已由 AI 生成過的回覆
              </div>
            )}
          </div>
          <Card pad={32}>
            <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 20, gap: 12, flexWrap: "wrap" }}>
              <div style={{ display: "flex", alignItems: "center", gap: 8, flexWrap: "wrap" }}>
                <Pill tone="coralSoft">{toneLabel}</Pill>
                {isLoadingActive && <FeatureStatusPill slice={replySlice}/>}
                {isFailedActive && !isLoadingActive && <FeatureStatusPill slice={replySlice}/>}
              </div>
              <div style={{ display: "flex", gap: 8 }}>
                {isFailedActive && !isLoadingActive && (
                  <Btn tone="ghost" size="sm" onClick={retry}><Refresh size={12}/> 重試</Btn>
                )}
                <Btn tone="ink" size="sm" onClick={copy} disabled={!copyText}>
                  {copied ? <><Check size={12}/> 已複製</> : <><Copy size={12}/> 複製</>}
                </Btn>
              </div>
            </div>
            {isLoadingActive ? (
              <div>
                <div className="skel" style={{ height: 14, width: "88%", marginBottom: 10 }}/>
                <div className="skel" style={{ height: 14, width: "94%", marginBottom: 10 }}/>
                <div className="skel" style={{ height: 14, width: "72%", marginBottom: 10 }}/>
                <div className="skel" style={{ height: 14, width: "60%" }}/>
              </div>
            ) : replyText ? (
              <MarkdownView text={replyText}/>
            ) : mockEntry ? (
              <pre style={{
                fontFamily: "var(--sans)", fontSize: 14, lineHeight: 1.7,
                color: "var(--ink)", margin: 0, whiteSpace: "pre-wrap", letterSpacing: "-0.005em"
              }}>{mockEntry.body}</pre>
            ) : (
              <div style={{ fontSize: 14, color: "var(--g3)", lineHeight: 1.7 }}>
                點一下左側選項，AI 會立即針對該主題生成一則真誠的回覆草稿。
              </div>
            )}
          </Card>
        </div>
      </div>
    </section>
  );
};

