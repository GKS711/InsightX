    ink: { bg: "var(--ink)", fg: "var(--paper)", border: "var(--ink)" },
    paper: { bg: "var(--paper)", fg: "var(--ink)", border: "var(--paper)" },
    coral: { bg: "var(--coral)", fg: "var(--paper)", border: "var(--coral)" },
    blue: { bg: "var(--blue)", fg: "var(--paper)", border: "var(--blue)" },
    ghost: { bg: "transparent", fg: "var(--ink)", border: "var(--g1)" },
    ghostLight: { bg: "transparent", fg: "var(--paper)", border: "oklch(0.45 0 0)" }
  };
  const styles = palettes[tone] || palettes.ink;
  const Tag = href ? "a" : "button";
  return (
    <Tag onClick={onClick} disabled={disabled} href={href}
      style={{
        height: h, padding: `0 ${px}px`,
        background: styles.bg, color: styles.fg,
        border: `1px solid ${styles.border}`,
        borderRadius: 999, textDecoration: "none",
