<style>
  :root {
    /* Stripe-inspired palette (2026-04-21 color redesign)
       - 單一 accent = Stripe purple #635BFF
       - ink = Stripe deep navy (不用純黑，降低壓迫)
       - 灰階全系 Stripe-blue-tinted neutral scale
       - 背景固定純白，不鋪暖底色 */
    --ink: #0A2540;                         /* Stripe deep navy */
    --paper: #FFFFFF;
    --warm: #F6F9FC;                        /* 原本的 warm off-white → Stripe panel 藍灰 */
    --smoke: #F6F9FC;                       /* 與 --warm 同色，統一 off-white tint */
    --g1: #E6EBF1;                          /* 最淺 Stripe 灰（分隔線 / hover 底） */
    --g2: #AAB7C4;                          /* 中淺（placeholder / icon 弱色） */
    --g3: #8898AA;                          /* 中深（次要文字 / metadata） */
    --g4: #425466;                          /* 深灰（主要文字 contrast 用） */

    /* Accents — 收斂成「單一 Stripe 紫」single-accent system */
    --coral: #635BFF;                       /* 原 coral（暖橙）→ Stripe 紫 */
    --coral-soft: #EFEFFD;                  /* 紫淺底 */
    --blue: #635BFF;                        /* 原 apple-blue → 合流到主紫 */
    --blue-soft: #EFEFFD;

    /* Semantic — 低頻使用，只在明確語意場景出現 */
    --pos: #00C853;                         /* Stripe-like 米綠（正面數值 / success toast） */
    --neg: #FF5A5F;                         /* 涼紅（錯誤 / 負面 / 警示） */
    --neu: var(--g2);

    /* YouTube — Stripe 風不再特別標識，併入主 accent */
    --yt: #635BFF;

    /* Type — 保留 Manrope + Noto Sans TC + JetBrains Mono（下次風格調整再動） */
    --sans: "Manrope", "Noto Sans TC", -apple-system, BlinkMacSystemFont, "SF Pro Display", sans-serif;
    --mono: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
  }

  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
    font-family: var(--sans);
    background: var(--paper);
    color: var(--ink);
    -webkit-font-smoothing: antialiased;
    line-height: 1.45;
    font-feature-settings: "ss01", "ss02", "cv11", "tnum";
  }
  button { font-family: inherit; cursor: pointer; }
  input, textarea { font-family: inherit; }
  ::selection { background: var(--ink); color: var(--paper); }

  .mono { font-family: var(--mono); font-feature-settings: "tnum"; }
  .tabular { font-variant-numeric: tabular-nums; }

  /* Scrollbar */
  ::-webkit-scrollbar { width: 10px; height: 10px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: oklch(0.85 0 0); border-radius: 10px; }
  ::-webkit-scrollbar-thumb:hover { background: oklch(0.7 0 0); }

  /* Focus */
  :focus-visible { outline: 2px solid var(--blue); outline-offset: 2px; border-radius: 4px; }

  /* Prevent flash */
  #root:empty::before {
    content: "";
    position: fixed; inset: 0;
    background: var(--paper);
    z-index: 9999;
  }

  /* Utilities */
  .kicker {
    font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase;
    font-weight: 600; color: var(--g3);
  }
  .tag {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 4px 10px; font-size: 11px; font-weight: 500;
    border-radius: 999px; letter-spacing: 0.02em;
  }

  /* Animations */
  @keyframes fadeUp { from { opacity: 0; transform: translateY(14px); } to { opacity: 1; transform: none; } }
  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
  @keyframes growBar { from { transform: scaleX(0); } to { transform: scaleX(1); } }
  @keyframes dotPulse { 0%,100% { opacity: 0.3; transform: scale(0.8); } 50% { opacity: 1; transform: scale(1.05); } }
  @keyframes shine { 0% { transform: translateX(-100%); } 100% { transform: translateX(100%); } }
  @keyframes floaty { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-4px); } }

  .fade-up { animation: fadeUp 0.7s cubic-bezier(.2,.7,.2,1) both; }
  .fade-in { animation: fadeIn 0.4s ease both; }

  /* Reveal-on-scroll */
  .reveal { opacity: 0; transform: translateY(20px); transition: opacity .8s cubic-bezier(.2,.7,.2,1), transform .8s cubic-bezier(.2,.7,.2,1); }
  .reveal.in { opacity: 1; transform: none; }

  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { scrollbar-width: none; }

  /* Screen transitions */
  .screen { animation: fadeIn .4s ease both; }

  /* Dark section — inverts palette locally */
  .dark {
    background: var(--ink); color: var(--paper);
  }
  .dark .kicker { color: oklch(0.72 0 0); }

  /* Markdown content — LLM output 渲染（tiny parser 出的 class） */
  .md-view { font-family: var(--sans); color: var(--ink); line-height: 1.65; font-size: 14px; letter-spacing: -0.005em; }
  .md-view h2 { font-size: 22px; font-weight: 500; letter-spacing: -0.02em; margin: 28px 0 10px; color: var(--ink); }
  .md-view h3 { font-size: 18px; font-weight: 600; letter-spacing: -0.015em; margin: 22px 0 8px; color: var(--ink); }
  .md-view h4 { font-size: 15px; font-weight: 600; letter-spacing: -0.01em; margin: 18px 0 6px; color: var(--g4); text-transform: none; }
  .md-view p { margin: 6px 0; color: var(--g4); }
  .md-view p.md-ol { margin: 4px 0; color: var(--g4); padding-left: 4px; }
  .md-view ul { margin: 8px 0 12px; padding-left: 20px; }
  .md-view li { margin: 4px 0; color: var(--g4); line-height: 1.6; }
  .md-view code { font-family: var(--mono); font-size: 12.5px; background: var(--smoke); padding: 1px 6px; border-radius: 4px; color: var(--ink); }
  .md-view strong { color: var(--ink); font-weight: 600; }
  .md-view em { color: var(--g4); font-style: italic; }
  .md-view .md-break { height: 6px; }
  .md-view.dark { color: var(--paper); }
  .md-view.dark h2, .md-view.dark h3, .md-view.dark h4, .md-view.dark strong { color: var(--paper); }
  .md-view.dark p, .md-view.dark li, .md-view.dark p.md-ol, .md-view.dark em { color: oklch(0.8 0 0); }
  .md-view.dark code { background: oklch(0.2 0 0); color: var(--paper); }

  /* Skeleton loader 線條 — 用 CSS keyframe 做出 shimmer 效果 */
  .skel { background: linear-gradient(90deg, var(--smoke) 0%, var(--g1) 50%, var(--smoke) 100%); background-size: 200% 100%; animation: skelShimmer 1.3s infinite linear; border-radius: 6px; }
  @keyframes skelShimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }
  .dark .skel { background: linear-gradient(90deg, oklch(0.18 0 0) 0%, oklch(0.26 0 0) 50%, oklch(0.18 0 0) 100%); background-size: 200% 100%; }

  /* Responsive */
  .show-sm { display: none !important; }
  @media (max-width: 900px) {
    .pick-grid { grid-template-columns: 1fr !important; gap: 16px !important; }
    .two-col { grid-template-columns: 1fr !important; gap: 32px !important; }
    .three-col { grid-template-columns: 1fr !important; }
    .four-col { grid-template-columns: 1fr 1fr !important; }
    .hero-stat-grid { grid-template-columns: 1fr !important; }
    .hero-stat-grid > * { border-right: none !important; border-bottom: 1px solid var(--g1) !important; }
