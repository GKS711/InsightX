// ===== ix2/ix-context.jsx =====
// ===== IX Store Provider — 接 v4 reducer + SSE hook 到 Babel 區塊 =====
//
// bootstrap.js（/bootstrap.js, type="module"）已把 hooks/core 掛在 window.IX。
// 瀏覽器規格：type="module" 是 deferred，Babel standalone 在 DOMContentLoaded 才
// 掃 text/babel，所以這裡取用 window.IX 時一定已經就緒。

const IXContext = React.createContext(null);

const useIX = () => {
  const ctx = React.useContext(IXContext);
  if (!ctx) throw new Error("useIX() 必須在 <IXStoreProvider> 內使用");
  return ctx;
};

const IXStoreProvider = ({ children }) => {
  const ixLib = window.IX;
  if (!ixLib) {
    // 理論上不會發生（見 bootstrap.js 註解）；保底顯示訊息
    return (
      <div style={{ padding: 48, fontFamily: "var(--sans)", color: "var(--ink)" }}>
        正在載入 bootstrap…（若長時間卡住請 reload）
      </div>
    );
  }
  const { state, dispatch } = ixLib.useAppReducer();
  const stream = ixLib.useAnalyzeStream(dispatch);

  const value = React.useMemo(
    () => ({ state, dispatch, stream, lib: ixLib }),
    [state, dispatch, stream, ixLib]
  );
  return <IXContext.Provider value={value}>{children}</IXContext.Provider>;
};

// ===== ix2/view-models.jsx =====
// ===== View-model helpers — 把 state.features.analyze.data 映射成 Shop/YT dashboard 期望的 shape =====
//
// 設計原則：
//   - 後端 /api/analyze 只吐 {store_name, platform, total_reviews, good[], bad[]}；
//     其餘欄位（SWOT 詳述、review quote、week plan…）都來自後續 8 個 feature endpoints 或 mock。
//   - 真實資料覆蓋 mock 的「對應欄位」，其他欄位保留 mock，這樣 demo 畫面始終完整。
//   - hasRealData=true 表示至少跑過一次 analyze，UI 可以用它決定是否顯示「示範資料」標記。
//
// **payload 結構重點**：
//   SSE `result` event payload 是 {platform, effective_yt_role, durationMs, data: {...LLM output}}，
//   reducer 把整個 payload 原封不動存進 features.analyze.data，所以取真實欄位要走 analyze.data.data.*。
//   unwrapAnalyze() 負責抽出裡面真正的 LLM output。

const unwrapAnalyze = (raw) => {
  if (!raw || typeof raw !== "object") return null;
  // SSE 封裝：{platform, effective_yt_role, durationMs, data: {...}}
  if (raw.data && typeof raw.data === "object" && ("store_name" in raw.data || "good" in raw.data || "bad" in raw.data)) {
    return raw.data;
  }
  // 非 SSE fallback（POST /api/analyze 直接回）
  if ("store_name" in raw || "good" in raw || "bad" in raw) return raw;
  return null;
};

const parseReviewCount = (raw) => {
  if (raw == null) return null;
  const m = String(raw).match(/\d+(?:,\d+)*/);
  if (!m) return null;
  const n = Number(m[0].replace(/,/g, ""));
  return Number.isFinite(n) ? n : null;
};

// hasReal=true 時不再用 mock fallback（避免把示範句子當成真實顧客留言）
// backend 的 good[]/bad[] 沒有 sample 欄位，若有（未來擴充）會沿用
const mapShopThemes = (arr, mockBase, totalReviewsNum, hasReal) => {
  if (!Array.isArray(arr) || arr.length === 0) return hasReal ? [] : mockBase;
  const denom = totalReviewsNum || 100;
  return arr.map((t, i) => {
    const pct = Math.max(0, Math.min(100, Math.round(Number(t.value) || 0)));
    return {
      label: t.label || `主題${i + 1}`,
      pct,
      count: Math.max(0, Math.round((pct / 100) * denom)),
      // 只接受 backend 真的吐的 sample；沒有就空字串，UI 端會自動隱藏
      sample: typeof t.sample === "string" ? t.sample
            : typeof t.example === "string" ? t.example
            : hasReal ? "" : (mockBase[i]?.sample || ""),
      severity: t.severity || (hasReal ? "mid" : (mockBase[i]?.severity || "mid")),
    };
  });
};

const buildShopViewModel = (analyzeData) => {
  const d = unwrapAnalyze(analyzeData);
  const hasReal = !!d;
  const totalReviewsNum = parseReviewCount(d?.total_reviews);

  // backend reviews_structured: [{text, rating, author, time}]；過濾掉無文字的
  const reviewsReal = Array.isArray(d?.reviews_structured)
    ? d.reviews_structured.filter((r) => r && typeof r.text === "string" && r.text.trim().length > 0)
    : [];

  // 真實情感分布：用 reviews_structured 的 rating 聚合
  //   rating >= 4 → 正向；rating === 3 → 中性；rating 1–2 → 負面；0/缺 → 跳過
  // 若完全沒 rating 可用則 fallback：僅顯示佔比全 0、UI 元件自行 guard
  let sentimentPos = 0, sentimentNeu = 0, sentimentNeg = 0;
  if (hasReal) {
    const ratedReviews = reviewsReal.filter(
      (r) => typeof r.rating === "number" && r.rating >= 1 && r.rating <= 5
    );
    const denom = ratedReviews.length;
    if (denom > 0) {
      const cPos = ratedReviews.filter((r) => r.rating >= 4).length;
      const cNeg = ratedReviews.filter((r) => r.rating <= 2).length;
      const cNeu = denom - cPos - cNeg;
      sentimentPos = Math.round((cPos / denom) * 100);
      sentimentNeg = Math.round((cNeg / denom) * 100);
      sentimentNeu = Math.max(0, 100 - sentimentPos - sentimentNeg);
    }
  }

  const shopReal = {
    name: d?.store_name || null,
    nameZh: d?.store_name || null,
    subline: null,
    // backend 已 pipe 的 Serper /maps metadata
    address: typeof d?.address === "string" && d.address.trim() ? d.address : null,
    category: typeof d?.category === "string" && d.category.trim() ? d.category : null,
    rating: (typeof d?.rating === "number" && Number.isFinite(d.rating)) ? d.rating : null,
    ratingCount: (typeof d?.rating_count === "number" && Number.isFinite(d.rating_count)) ? d.rating_count : null,
    reviewCount: totalReviewsNum,
    // backend 暫無這兩欄
    hours: null,
    googleUrl: null,
  };

  return {
    hasRealData: hasReal,
    shop: hasReal ? shopReal : { ...SHOP },
    themesPos: mapShopThemes(d?.good, THEMES_POS, totalReviewsNum, hasReal),
    themesNeg: mapShopThemes(d?.bad, THEMES_NEG, totalReviewsNum, hasReal),
    sentiment: hasReal
      ? { positive: sentimentPos, neutral: sentimentNeu, negative: sentimentNeg }
      : { ...SENTIMENT },
    totalReviews: hasReal ? (totalReviewsNum || reviewsReal.length || 0) : SHOP.reviewCount,
    reviews: reviewsReal, // hasReal=false 時 UI 會自己用 REVIEWS mock
  };
};

const buildYouTubeViewModel = (analyzeData) => {
  const d = unwrapAnalyze(analyzeData);
  const totalReviewsNum = parseReviewCount(d?.total_reviews);

  // 把 good/bad 合併成 YT 的 commentThemes shape — pos 先、neg 後
  const commentThemes = (() => {
    if (!d || (!d.good?.length && !d.bad?.length)) return YT_COMMENT_THEMES;
    const denom = totalReviewsNum || 100;
    const out = [];
    (d.good || []).forEach((t, i) => {
      const pct = Math.max(0, Math.min(100, Math.round(Number(t.value) || 0)));
      out.push({
        label: t.label || `正面${i + 1}`,
        pct,
        count: Math.max(0, Math.round((pct / 100) * denom)),
        tone: "pos",
        sample: YT_COMMENT_THEMES[i]?.sample || "",
      });
    });
    (d.bad || []).forEach((t, i) => {
      const pct = Math.max(0, Math.min(100, Math.round(Number(t.value) || 0)));
      out.push({
        label: t.label || `負面${i + 1}`,
        pct,
        count: Math.max(0, Math.round((pct / 100) * denom)),
        tone: "neg",
        sample: YT_COMMENT_THEMES.slice(3)[i]?.sample || "",
      });
    });
    return out;
  })();

  return {
    hasRealData: !!d,
    video: {
      ...YT_VIDEO,
      ...(d?.store_name ? { title: d.store_name } : {}),
      ...(totalReviewsNum != null ? { commentsTotal: totalReviewsNum, commentsAnalyzed: totalReviewsNum } : {}),
    },
    commentThemes,
  };
};

const useShopViewModel = () => {
  const ix = useIX();
  const analyzeData = ix.state.features.analyze.data;
  return React.useMemo(() => buildShopViewModel(analyzeData), [analyzeData]);
};

const useYouTubeViewModel = () => {
  const ix = useIX();
  const analyzeData = ix.state.features.analyze.data;
  return React.useMemo(() => buildYouTubeViewModel(analyzeData), [analyzeData]);
};

// ===== ix2/feature-helpers.jsx =====
// 共用 helper：
//   - tinyMarkdown / MarkdownView — 把 LLM 輸出的 markdown 渲染成 HTML（無外部依賴，避免 XSS 重點在於先 escape 再做最小規則替換）
//   - joinGood / joinBad — 把 analyze 的 good[]/bad[] 合成單一字串（符合 7 個 feature endpoint 的 body.topic/.strengths/.weaknesses/.issue 約定）
//   - FeatureStatusPill — 小元件，顯示 loading / failed / fallback 狀態

const tinyMarkdownEscape = (s) => String(s ?? "")
  .replace(/&/g, "&amp;")
  .replace(/</g, "&lt;")
  .replace(/>/g, "&gt;");

const tinyMarkdownInline = (esc) => esc
  .replace(/\*\*([^*]+)\*\*/g, "<strong>$1</strong>")
  .replace(/`([^`]+)`/g, "<code>$1</code>")
  .replace(/\*([^*]+)\*/g, "<em>$1</em>");

const tinyMarkdown = (text) => {
  if (!text) return "";
  const lines = String(text).split(/\r?\n/);
  let html = "";
  let inList = false;
  const flushList = () => { if (inList) { html += "</ul>"; inList = false; } };
  lines.forEach((raw) => {
    const line = raw;
    if (/^###\s+/.test(line)) {
      flushList();
      html += `<h4>${tinyMarkdownInline(tinyMarkdownEscape(line.replace(/^###\s+/, "")))}</h4>`;
    } else if (/^##\s+/.test(line)) {
      flushList();
      html += `<h3>${tinyMarkdownInline(tinyMarkdownEscape(line.replace(/^##\s+/, "")))}</h3>`;
    } else if (/^#\s+/.test(line)) {
      flushList();
      html += `<h2>${tinyMarkdownInline(tinyMarkdownEscape(line.replace(/^#\s+/, "")))}</h2>`;
    } else if (/^[-*]\s+/.test(line)) {
      if (!inList) { html += `<ul>`; inList = true; }
      const item = tinyMarkdownInline(tinyMarkdownEscape(line.replace(/^[-*]\s+/, "")));
      html += `<li>${item}</li>`;
    } else if (/^\d+\.\s+/.test(line)) {
      flushList();
      html += `<p class="md-ol">${tinyMarkdownInline(tinyMarkdownEscape(line))}</p>`;
    } else if (line.trim() === "") {
      flushList();
      html += "<div class=\"md-break\"></div>";
    } else {
      flushList();
      html += `<p>${tinyMarkdownInline(tinyMarkdownEscape(line))}</p>`;
    }
  });
  flushList();
  return html;
};

const MarkdownView = ({ text, className, style }) => {
  const html = React.useMemo(() => tinyMarkdown(text), [text]);
  return (
    <div
      className={"md-view " + (className || "")}
      style={style}
      dangerouslySetInnerHTML={{ __html: html }}
    />
  );
};

// 把 good[]/bad[] 合成後端期望的字串 topic
const joinThemesAsText = (arr, max = 5) => {
  if (!Array.isArray(arr) || arr.length === 0) return "";
  return arr
    .slice(0, max)
    .map((t) => (typeof t === "string" ? t : `${t.label || ""}${t.value != null ? `（${t.value}%）` : ""}`))
    .filter(Boolean)
    .join("、");
};

// 小元件：顯示 adapter async state
const FeatureStatusPill = ({ slice, fallbackText = "示範資料" }) => {
  if (!slice) return null;
  if (slice.status === "loading") {
    return (
      <Pill tone="smoke" size="sm" style={{ color: "var(--g3)" }}>
        <Dot size={5} color="var(--coral)"/> AI 生成中…
      </Pill>
    );
  }
  if (slice.status === "failed") {
    return (
      <Pill tone="smoke" size="sm" style={{ color: "var(--neg)" }}>
        <Dot size={5} color="var(--neg)"/> 載入失敗（顯示{fallbackText}）
      </Pill>
    );
  }
  return null;
};

// ===== ix2/app.jsx =====
// ===== App — top-level router for InsightX v2 =====

const App = () => {
  const [phase, setPhase] = React.useState("landing");  // landing | shop | yt
  const [ytRole, setYtRole] = React.useState("creator");
  const [tweaks, setTweaksState] = React.useState(() => window.TWEAKS || {});
  const [chatOpen, setChatOpen] = React.useState(false);

  const setTweak = (patch) => {
    setTweaksState(prev => ({ ...prev, ...patch }));
  };

  const onComplete = ({ mode, ytRole }) => {
    if (mode === "youtube") {
      setYtRole(ytRole || "creator");
      setPhase("yt");
    } else {
      setPhase("shop");
    }
    window.scrollTo(0, 0);
  };

  const jump = (k) => {
    if (k === "landing") setPhase("landing");
    else if (k === "shop") setPhase("shop");
    else if (k === "yt-creator") { setYtRole("creator"); setPhase("yt"); }
    else if (k === "yt-shop") { setYtRole("shop"); setPhase("yt"); }
    else if (k === "yt-brand") { setYtRole("brand"); setPhase("yt"); }
    window.scrollTo(0, 0);
  };

  return (
    <div data-screen-label={`v2 · ${phase}`}>
      {phase === "landing" && <LandingPage onComplete={onComplete}/>}
      {phase === "shop" && <>
        <DashNav label="店家模式" onHome={() => jump("landing")}
                 onOpenChat={() => setChatOpen(true)}/>
        <ShopDashboard/>
        <ShopToolkit/>
        <FooterV2/>
      </>}
      {phase === "yt" && <>
        <DashNav label={`YouTube · ${ {creator:"創作者", shop:"店家", brand:"品牌"}[ytRole] }視角`}
                 onHome={() => jump("landing")}
                 onOpenChat={() => setChatOpen(true)}/>
        <YouTubeDashboard role={ytRole}/>
        <FooterV2/>
      </>}

      <TweaksPanel tweaks={tweaks} setTweak={setTweak} onJump={jump}/>
      {phase !== "landing" && <ChatDock open={chatOpen} onClose={() => setChatOpen(false)}/>}
    </div>
  );
};

