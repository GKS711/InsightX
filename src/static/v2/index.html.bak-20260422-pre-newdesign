// ===== Landing (v2) — Apple product-page feel with mode picker =====
// Flow: hero → mode picker (shop vs youtube) → input → analyzing → dashboard

const LandingPage = ({ onComplete, initialMode = "shop" }) => {
  const ix = useIX();
  const [phase, setPhase] = React.useState("choose");     // choose | input | analyzing
  const [mode, setMode] = React.useState(null);           // "shop" | "youtube"
  const [ytRole, setYtRole] = React.useState(null);       // "creator" | "shop" | "brand"
  const [url, setUrl] = React.useState("");
  const inputRef = React.useRef(null);

  const SHOP_STEPS = [
    { k: "抓取 Google 評論", d: "掃描 Google 地圖，共 847 則" },
    { k: "清洗與去重", d: "剔除廣告、重複、非真實顧客留言" },
    { k: "主題聚類", d: "歸納出顧客自然談論的 10 大主題" },
    { k: "情感判讀", d: "正向、中性、負面與情緒強度" },
    { k: "生成 SWOT", d: "每一項都有評論佐證" },
    { k: "寫出這週的三件事", d: "可執行的清單，不是空話" }
  ];

  const YT_STEPS = [
    { k: "抓取影片資料", d: "標題、留言、互動數據" },
    { k: "分析留言情感", d: "逐則判讀正負向與主題" },
    { k: "找出關鍵時刻", d: "觀眾反應最熱烈的秒數" },
    { k: "整理觀眾問題", d: "留言裡反覆被問的事" },
    { k: "根據身份給建議", d: "創作者 / 店家 / 品牌的下一步" }
  ];

  const steps = mode === "youtube" ? YT_STEPS : SHOP_STEPS;

  const canStart = url.trim().length > 8;

  const pickMode = (m) => {
    setMode(m);
    setPhase("input");
    setTimeout(() => inputRef.current?.focus(), 200);
  };

  // 把 UI 的 "shop"/"youtube" 映到 reducer 的 "google"/"youtube"
  const toPlatform = (m) => (m === "youtube" ? "youtube" : "google");

  const start = () => {
    if (!canStart) return;
    const platform = toPlatform(mode);
    // 同步 reducer 狀態，reducer 是 source of truth
    ix.dispatch({ type: "INPUT_CHANGE", platform, value: url });
    ix.dispatch({ type: "SWITCH_PLATFORM", platform });
    if (platform === "youtube" && ytRole) {
      ix.dispatch({ type: "SWITCH_YT_ROLE", ytRole });
    }
    setPhase("analyzing");
    // 發 SSE；stream reducer 會把 phase 推到 connecting → streaming
    ix.stream.start({
      url: url.trim(),
      platform,
      ytRole: platform === "youtube" ? ytRole : null,
    });
  };

  // 監聽 SSE phase：succeeded 自動 onComplete；failed/canceled 停留在 analyzing 顯示錯誤
  const streamState = ix.state.stream;
  React.useEffect(() => {
    if (phase !== "analyzing") return;
    if (streamState.phase === "succeeded") {
      const t = setTimeout(() => onComplete({ mode, ytRole }), 400);
      return () => clearTimeout(t);
    }
  }, [streamState.phase, phase]);

  // 用 progress 比例推出目前 step index（0..steps.length），AnalyzingBlock 用來點亮步驟
  const step = Math.min(
    Math.round((streamState.progress || 0) * steps.length),
    steps.length
  );

  const onAnalyzingBack = () => {
    ix.stream.stop();
    setPhase("input");
  };

  return (
    <div style={{ background: "var(--paper)", color: "var(--ink)", minHeight: "100vh" }}>
      <TopBar/>

      {phase === "choose" && <HeroBlock onStart={pickMode}/>}
      {phase === "input" && (
        <InputBlock mode={mode} url={url} setUrl={setUrl} onStart={start} canStart={canStart}
                    onBack={() => { setPhase("choose"); setMode(null); setUrl(""); setYtRole(null); }}
                    ytRole={ytRole} setYtRole={setYtRole}
                    inputRef={inputRef}/>
      )}
      {phase === "analyzing" && (
        <AnalyzingBlock
          steps={steps} step={step} mode={mode} url={url}
          streamState={streamState} onBack={onAnalyzingBack}
        />
      )}

      {phase === "choose" && <>
        <ValuePropBlock/>
        <StoryBlock/>
        <ComparePanelBlock/>
        <FooterBlock/>
      </>}
    </div>
  );
};

