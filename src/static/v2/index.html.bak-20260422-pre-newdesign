// 後端 SWOT shape: {strengths/weaknesses/opportunities/threats: [{point, detail}]}
// UI 期望 shape:  [{title, body}] — 做一次欄位轉換。
const normalizeSwotBucket = (arr, mockBase) => {
  if (!Array.isArray(arr) || arr.length === 0) return mockBase;
  return arr.map((it, i) => ({
    title: it.title || it.point || mockBase[i]?.title || `項目${i + 1}`,
    body: it.body || it.detail || mockBase[i]?.body || "",
  }));
};

const ShopSwotSection = () => {
  const ix = useIX();
  const vm = useShopViewModel();
  const swotSlice = ix.state.features.swot;
  const analyzeData = ix.state.features.analyze.data;

  // 當 analyze 拿到 good/bad 時，自動向後端 fetchSwot 一次（idempotent：只有 idle 才打）
  React.useEffect(() => {
    if (!analyzeData) return;
    if (swotSlice.status !== "idle") return;
    const inner = unwrapAnalyze(analyzeData);
    if (!inner) return;
    if (!Array.isArray(inner.good) || !Array.isArray(inner.bad)) return;
    if (inner.good.length === 0 && inner.bad.length === 0) return;
    const platform = ix.state.mode.currentPlatform;
    ix.lib.Adapters.fetchSwot({
      good: inner.good,
      bad: inner.bad,
      platform,
      ytRole: platform === "youtube" ? ix.state.mode.ytRoleSelection : null,
      dispatch: ix.dispatch,
    });
  }, [analyzeData, swotSlice.status]);

  // 取 real data 或 fallback 到 SWOT mock
  const real = swotSlice.status === "ready" ? swotSlice.data : null;
  const strengths = normalizeSwotBucket(real?.strengths, SWOT.strengths);
  const weaknesses = normalizeSwotBucket(real?.weaknesses, SWOT.weaknesses);
  const opportunities = normalizeSwotBucket(real?.opportunities, SWOT.opportunities);
  const threats = normalizeSwotBucket(real?.threats, SWOT.threats);
  const isLoading = swotSlice.status === "loading";
  const isFailed = swotSlice.status === "failed";

  return (
  <section style={{ padding: "140px 24px" }}>
    <div style={{ maxWidth: 1280, margin: "0 auto" }}>
      <Reveal>
        <SectionHead
          kicker={isLoading ? "§03 · SWOT 分析（AI 生成中…）" : isFailed ? "§03 · SWOT 分析（示範資料）" : "§03 · SWOT 分析"}
          title={<>優勢。劣勢。<br/>機會。威脅。</>}
          sub="每一項都有評論佐證，不是顧問的紙上談兵。"
        />
      </Reveal>

      <div className="swot-grid" style={{
        marginTop: 72, display: "grid", gridTemplateColumns: "1fr 1fr", gap: 0,
        border: "1px solid var(--g1)", borderRadius: 24, overflow: "hidden",
        opacity: isLoading ? 0.6 : 1, transition: "opacity 240ms ease"
      }}>
        <SwotCell label="S" title="優勢" items={strengths} tone="coral" border="right bottom"/>
        <SwotCell label="W" title="劣勢" items={weaknesses} tone="neg" border="bottom"/>
        <SwotCell label="O" title="機會" items={opportunities} tone="blue" border="right"/>
        <SwotCell label="T" title="威脅" items={threats} tone="ink" border=""/>
      </div>
    </div>
  </section>
  );
};

